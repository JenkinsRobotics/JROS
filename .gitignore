# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Notebooks
.ipynb_checkpoints/

# Models and weights (never commit — too large). The models/ folder
# itself is kept (models/README.md) so it exists for local dev; only
# the weight files inside are ignored.
*.gguf
*.bin
*.pt
*.pth
*.onnx
*.safetensors
models/*
!models/README.md
!models/.gitkeep

# Benchmark RUN OUTPUT — the suite code under benchmark/ is committed,
# but its generated reports / rows / logs are local artifacts.
benchmark/**/BENCHMARK_*.md
benchmark/**/*_rows.jsonl
benchmark/**/*.jsonl
benchmark/**/*.log

# JROS runtime artifacts
*.pid
*.log
.jros/
~/.jros/

# Local secrets
.env
.env.*
!.env.example
