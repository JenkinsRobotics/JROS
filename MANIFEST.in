include README.md
include LICENSE
include pyproject.toml

recursive-include src/jaeger_os *.md *.yaml *.json *.txt
recursive-include src/jaeger_os/prompts *
recursive-include src/jaeger_os/assets *
recursive-include src/jaeger_os/skills *

# INST-10 (0.2.0): src/jaeger_os/instance/ no longer exists. User
# state lives at ~/.jaeger/instances/<name>/ and is created by the
# wizard on first run; nothing about it ships in the wheel.

recursive-include "dev docs" *.md
recursive-include "dev docs/skill_template" *
recursive-include tests *.py
recursive-include benchmark *.py *.md

# 0.2.1: models/ moved to src/jaeger_os/models/. The README is
# already covered by ``recursive-include src/jaeger_os *.md`` above
# — no separate include line needed. Weight files are gitignored
# AND excluded from sdist via the *.gguf rule below.
global-exclude *.gguf

# Benchmark run output is local-only — never ship it in the sdist.
recursive-exclude benchmark BENCHMARK_*.md *_rows.jsonl *.log

global-exclude __pycache__ *.pyc *.pyo .DS_Store

# Vendored Hermes reference clone — local-only, never ships.
prune src/python_hermes_agent
