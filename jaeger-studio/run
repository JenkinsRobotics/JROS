#!/usr/bin/env bash
# Run the Studio app against a local mock instance, alongside your real JROS app.
# JROS runs separately (its own ./launch); this is the Studio half of the split.
#
#   ./run            # stub instance + Studio GUI
#   PY=/path/python ./run
set -e
cd "$(dirname "$0")"
PY="${PY:-../.venv/bin/python}"

"$PY" instance_stub.py &
STUB=$!
trap 'kill $STUB 2>/dev/null' EXIT
sleep 1.2
"$PY" -m studio_app --port 45560
