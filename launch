#!/bin/bash
# launch — thin shell wrapper around launch.py.
#
# Why this exists: ``./launch.py``'s ``#!/usr/bin/env python3`` resolves
# to whatever ``python3`` is first on PATH.  On this host (and most
# pyenv-using hosts) that's a pyenv shim picking up a broken 3.13.7
# install whose hashlib floods stderr with ``ValueError: unsupported
# hash type blake2b`` at INTERPRETER STARTUP — before any user code can
# react.  The Python-side bootstrap in launch.py can re-exec into the
# repo venv, but it can't suppress noise that happens before its
# imports run.
#
# This wrapper sidesteps that entirely: it picks ``.venv/bin/python``
# itself, so pyenv's shim is never invoked.  Same behavior, no noise.
#
# Both ``./launch`` and ``./launch.py`` work — the .py form still
# self-relocates (kept as a safety net for direct python invocations).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="$REPO_ROOT/.venv/bin/python"

if [ ! -x "$VENV_PY" ]; then
  echo "[launch] $VENV_PY not found — run ./install.sh first" >&2
  exit 1
fi

exec "$VENV_PY" "$REPO_ROOT/launch.py" "$@"
